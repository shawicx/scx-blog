# Environment variables for SCX Blog

# Cloudflare Pages Environment
CLOUDFLARE_ENV=production

# Build Configuration
PUBLIC_SITE_URL=https://scx-blog.pages.dev

# Analytics (if needed)
# ANALYTICS_ID=

# API Keys (example)
# API_KEY=

# GitHub Personal Access Token
# Create your token at: https://github.com/settings/tokens
# Required scopes: read:org, read:user, repo (read-only)
# Used for fetching contribution data on the stats page
GITHUB_TOKEN=ghp_your_token_here