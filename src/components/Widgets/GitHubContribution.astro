---
/**
 * GitHubContribution.astro
 *
 * Displays a GitHub contribution calendar similar to GitHub's profile page.
 * Uses GraphQL API to fetch contribution data with caching support.
 */

interface Props {
  username: string
  token?: string
  title?: string
  showTotal?: boolean
}

const {
  username,
  token,
  title = 'GitHub 贡献',
  showTotal = true,
} = Astro.props

// Generate unique container ID
const containerId = `github-contribution-${username}`
---

<!-- Contribution Calendar Container -->
<div
  id={containerId}
  class="github-contribution-container"
  data-username={username}
  data-token={token || ''}
  data-title={title}
  data-show-total={showTotal ? 'true' : 'false'}
>
  <!-- Loading Skeleton -->
  <div class="gc-loading">
    <div class="gc-skeleton-header"></div>
    <div class="gc-skeleton-grid">
      <div class="gc-skeleton-week">
        <div></div><div></div><div></div><div></div><div></div><div></div><div></div>
      </div>
      <div class="gc-skeleton-week">
        <div></div><div></div><div></div><div></div><div></div><div></div><div></div>
      </div>
      <div class="gc-skeleton-week">
        <div></div><div></div><div></div><div></div><div></div><div></div><div></div>
      </div>
      <div class="gc-skeleton-week">
        <div></div><div></div><div></div><div></div><div></div><div></div><div></div>
      </div>
      <div class="gc-skeleton-week">
        <div></div><div></div><div></div><div></div><div></div><div></div><div></div>
      </div>
      <div class="gc-skeleton-week">
        <div></div><div></div><div></div><div></div><div></div><div></div><div></div>
      </div>
      <div class="gc-skeleton-week">
        <div></div><div></div><div></div><div></div><div></div><div></div><div></div>
      </div>
    </div>
    <div class="gc-skeleton-legend"></div>
  </div>
</div>

<style>
  /* Global styles for dynamically generated content */
  :global(.github-contribution-container) {
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 0.5rem;
    background-color: rgba(0, 0, 0, 0.02);
    padding: 1rem;
    margin-bottom: 1.5rem;
    font-family: system-ui, -apple-system, sans-serif;
  }

  :global(html.dark .github-contribution-container) {
    border-color: rgba(255, 255, 255, 0.05);
    background-color: rgba(255, 255, 255, 0.02);
  }

  /* Loading skeleton */
  :global(.gc-loading) {
    animation: gc-fade-in 0.3s ease-in;
  }

  @keyframes gc-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  :global(.gc-skeleton-header) {
    height: 1.5rem;
    width: 12rem;
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 0.25rem;
    margin-bottom: 1rem;
  }

  :global(html.dark .gc-skeleton-header) {
    background-color: rgba(255, 255, 255, 0.05);
  }

  :global(.gc-skeleton-grid) {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }

  :global(.gc-skeleton-week) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  :global(.gc-skeleton-week > div) {
    width: 0.75rem;
    height: 0.75rem;
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 0.125rem;
    animation: gc-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  :global(html.dark .gc-skeleton-week > div) {
    background-color: rgba(255, 255, 255, 0.05);
  }

  :global(.gc-skeleton-week > div:nth-child(1)) { animation-delay: 0ms; }
  :global(.gc-skeleton-week > div:nth-child(2)) { animation-delay: 50ms; }
  :global(.gc-skeleton-week > div:nth-child(3)) { animation-delay: 100ms; }
  :global(.gc-skeleton-week > div:nth-child(4)) { animation-delay: 150ms; }
  :global(.gc-skeleton-week > div:nth-child(5)) { animation-delay: 200ms; }
  :global(.gc-skeleton-week > div:nth-child(6)) { animation-delay: 250ms; }
  :global(.gc-skeleton-week > div:nth-child(7)) { animation-delay: 300ms; }

  @keyframes gc-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  :global(.gc-skeleton-legend) {
    height: 1rem;
    width: 8rem;
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 0.25rem;
    margin-left: auto;
  }

  :global(html.dark .gc-skeleton-legend) {
    background-color: rgba(255, 255, 255, 0.05);
  }

  /* Header */
  :global(.gc-header) {
    margin-bottom: 1rem;
  }

  :global(.gc-header h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: oklch(25% 0.005 298);
    margin-bottom: 0.25rem;
  }

  :global(html.dark .gc-header h3) {
    color: oklch(92% 0.005 298);
  }

  :global(.gc-header p) {
    font-size: 0.875rem;
    color: oklch(40% 0.005 298 / 0.7);
  }

  :global(html.dark .gc-header p) {
    color: oklch(77% 0.005 298 / 0.7);
  }

  /* Grid container */
  :global(.gc-grid-container) {
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.1) transparent;
  }

  :global(html.dark .gc-grid-container) {
    scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
  }

  :global(.gc-grid) {
    display: flex;
    gap: 0.25rem;
    min-width: max-content;
    padding-bottom: 0.5rem;
  }

  :global(.gc-week) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* Day cells - hover effects only */
  :global(.gc-day:hover) {
    transform: scale(1.25) !important;
    z-index: 10;
    box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.1);
  }

  :global(html.dark .gc-day:hover) {
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.2);
  }

  /* Legend */
  :global(.gc-legend) {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: oklch(40% 0.005 298 / 0.6);
    margin-top: 0.5rem;
    height: 1rem;
  }

  :global(html.dark .gc-legend) {
    color: oklch(77% 0.005 298 / 0.6);
  }

  :global(.gc-legend span) {
    margin-left: 0.25rem;
    margin-right: 0.25rem;
  }

  /* Tooltip */
  :global(.gc-tooltip) {
    position: fixed;
    background-color: oklch(96% 0.005 298);
    color: oklch(25% 0.005 298);
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    pointer-events: none;
    z-index: 50;
    white-space: nowrap;
  }

  :global(html.dark .gc-tooltip) {
    background-color: oklch(22% 0.005 298);
    color: oklch(92% 0.005 298);
  }

  /* Error state */
  :global(.gc-error) {
    text-align: center;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  :global(.gc-error p) {
    color: oklch(40% 0.005 298 / 0.6);
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  :global(html.dark .gc-error p) {
    color: oklch(77% 0.005 298 / 0.6);
  }

  :global(.gc-error a) {
    color: oklch(25% 0.005 298);
    font-size: 0.875rem;
    text-decoration: none;
  }

  :global(html.dark .gc-error a) {
    color: oklch(92% 0.005 298);
  }

  :global(.gc-error a:hover) {
    text-decoration: underline;
  }

  :global(.gc-retry-btn) {
    margin-top: 0.75rem;
    padding: 0.5rem 1rem;
    background-color: oklch(25% 0.005 298 / 0.1);
    color: oklch(25% 0.005 298);
    border-radius: 0.25rem;
    font-size: 0.875rem;
    transition: background-color 150ms;
    cursor: pointer;
    border: none;
  }

  :global(html.dark .gc-retry-btn) {
    background-color: oklch(92% 0.005 298 / 0.1);
    color: oklch(92% 0.005 298);
  }

  :global(.gc-retry-btn:hover) {
    background-color: oklch(25% 0.005 298 / 0.2);
  }

  :global(html.dark .gc-retry-btn:hover) {
    background-color: oklch(92% 0.005 298 / 0.2);
  }

  /* Responsive */
  @media (max-width: 768px) {
    :global(.github-contribution-container) {
      padding: 0.75rem;
    }

    :global(.gc-day) {
      width: 0.75rem;
      height: 0.75rem;
    }
  }
</style>

<script>
interface ContributionDay {
  date: string
  count: number
  level: 'NONE' | 'FIRST_QUARTILE' | 'SECOND_QUARTILE' | 'THIRD_QUARTILE' | 'FOURTH_QUARTILE'
}

interface ContributionWeek {
  firstDay: string
  days: ContributionDay[]
}

interface ContributionData {
  totalContributions: number
  weeks: ContributionWeek[]
  login: string
}

let tooltip: HTMLElement | null = null
const contributionDataCache = new Map<string, ContributionData>()

/**
 * Load contribution graph data and render
 */
async function loadContributionGraph(container: HTMLElement): Promise<void> {
  const username = container.dataset.username
  const token = container.dataset.token
  const title = container.dataset.title || 'GitHub 贡献'
  const showTotal = container.dataset.showTotal === 'true'

  if (!username) {
    console.error('GitHub username is required')
    renderError(container, username || '', '缺少用户名')
    return
  }

  try {
    // Dynamic import to avoid bundling issues
    const { fetchContributions } = await import('@/utils/github')

    // Fetch contribution data
    const data: ContributionData = await fetchContributions(username, token || undefined)

    // Cache the data for theme switching
    contributionDataCache.set(username, data)

    // Render the graph
    renderContributionGraph(container, data, { title, showTotal })

    // Setup theme change listener
    setupThemeChangeListener(container, username, { title, showTotal })
  }
  catch (error) {
    console.error('Failed to load GitHub contributions:', error)
    const errorMessage = error instanceof Error ? error.message : '加载失败'
    renderError(container, username, errorMessage, true)
  }
}

/**
 * Setup theme change listener
 */
function setupThemeChangeListener(
  container: HTMLElement,
  username: string,
  options: { title: string, showTotal: boolean },
): void {
  // Use MutationObserver to watch for class changes on html element
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
        // Theme changed, re-render with cached data
        const data = contributionDataCache.get(username)
        if (data) {
          renderContributionGraph(container, data, options)
        }
      }
    })
  })

  // Start observing the html element for class changes
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  })

  // Store observer reference for cleanup
  ;(container as any)._themeObserver = observer
}

/**
 * Render the contribution calendar
 */
function renderContributionGraph(
  container: HTMLElement,
  data: ContributionData,
  options: { title: string, showTotal: boolean },
): void {
  const { title, showTotal } = options

  // Generate HTML
  container.innerHTML = `
      <div class="gc-header">
        <h3>${escapeHtml(title)}</h3>
        ${showTotal
          ? `
          <p>
            过去一年共 <span class="font-semibold">${data.totalContributions.toLocaleString()}</span> 次贡献
          </p>
        `
          : ''}
      </div>

      <div class="gc-grid-container">
        <div class="gc-grid">
          ${renderWeeks(data.weeks)}
        </div>
      </div>

      <div class="gc-legend">
        <span>少</span>
        ${['NONE', 'FIRST_QUARTILE', 'SECOND_QUARTILE', 'THIRD_QUARTILE', 'FOURTH_QUARTILE'].map((level) => {
          const isDark = document.documentElement.classList.contains('dark')
          const colors: Record<string, { light: string, dark: string }> = {
            NONE: { light: 'rgb(235 237 237)', dark: 'rgb(30 35 42)' },
            FIRST_QUARTILE: { light: 'rgb(198 228 214)', dark: 'rgb(37 101 73)' },
            SECOND_QUARTILE: { light: 'rgb(123 201 150)', dark: 'rgb(45 136 85)' },
            THIRD_QUARTILE: { light: 'rgb(53 162 103)', dark: 'rgb(63 165 82)' },
            FOURTH_QUARTILE: { light: 'rgb(33 126 80)', dark: 'rgb(75 163 67)' },
          }
          const color = colors[level]?.[isDark ? 'dark' : 'light'] || colors.NONE.light
          return `<div style="background-color: ${color}; width: 0.75rem; height: 0.75rem; border-radius: 0.125rem;"></div>`
        }).join('')}
        <span>多</span>
      </div>
    `

  // Setup tooltip interaction
  setupTooltips(container)
}

/**
 * Render weeks HTML
 */
function renderWeeks(weeks: ContributionWeek[]): string {
  // Background colors for each contribution level
  const levelColors: Record<string, { light: string, dark: string }> = {
    NONE: { light: 'rgb(235 237 237)', dark: 'rgb(30 35 42)' },
    FIRST_QUARTILE: { light: 'rgb(198 228 214)', dark: 'rgb(37 101 73)' },
    SECOND_QUARTILE: { light: 'rgb(123 201 150)', dark: 'rgb(45 136 85)' },
    THIRD_QUARTILE: { light: 'rgb(53 162 103)', dark: 'rgb(63 165 82)' },
    FOURTH_QUARTILE: { light: 'rgb(33 126 80)', dark: 'rgb(75 163 67)' },
  }

  const isDark = document.documentElement.classList.contains('dark')

  return weeks.map(week => `
      <div class="gc-week">
        ${week.days.map((day) => {
          const level = day.level || 'NONE'
          const color = levelColors[level]?.[isDark ? 'dark' : 'light'] || levelColors.NONE.light

          return `
            <div
              class="gc-day"
              data-date="${day.date}"
              data-count="${day.count}"
              data-level="${level}"
              tabindex="0"
              role="gridcell"
              aria-label="${formatDate(day.date)}: ${day.count} 次贡献"
              style="background-color: ${color}; width: 0.75rem; height: 0.75rem; border-radius: 0.125rem; transition: all 150ms; cursor: default; display: block;"
            ></div>
          `
        }).join('')}
      </div>
    `).join('')
}

/**
 * Setup tooltip functionality
 */
function setupTooltips(container: HTMLElement): void {
  const days = container.querySelectorAll('.gc-day[data-date]')

  days.forEach((day) => {
    const handleMouseEnter = () => {
      const date = day.getAttribute('data-date')
      const count = day.getAttribute('data-count')

      if (date && count) {
        showTooltip(day as HTMLElement, `${formatDate(date)}: ${count} 次贡献`)
      }
    }

    const handleMouseLeave = () => {
      hideTooltip()
    }

    day.addEventListener('mouseenter', handleMouseEnter)
    day.addEventListener('mouseleave', handleMouseLeave)
    day.addEventListener('focus', handleMouseEnter)
    day.addEventListener('blur', handleMouseLeave)
  })
}

/**
 * Show tooltip
 */
function showTooltip(target: HTMLElement, text: string): void {
  // Remove existing tooltip
  hideTooltip()

  // Create new tooltip
  tooltip = document.createElement('div')
  tooltip.className = 'gc-tooltip'
  tooltip.textContent = text
  document.body.appendChild(tooltip)

  // Position tooltip
  const rect = target.getBoundingClientRect()
  tooltip.style.top = `${rect.top - 30}px`
  tooltip.style.left = `${rect.left + (rect.width / 2) - (tooltip.offsetWidth / 2)}px`

  // Ensure tooltip doesn't overflow viewport
  const tooltipRect = tooltip.getBoundingClientRect()
  if (tooltipRect.top < 10) {
    tooltip.style.top = `${rect.bottom + 10}px`
  }
}

/**
 * Hide and remove tooltip
 */
function hideTooltip(): void {
  if (tooltip) {
    tooltip.remove()
    tooltip = null
  }
}

/**
 * Render error state
 */
function renderError(
  container: HTMLElement,
  username: string,
  message: string,
  showRetry = false,
): void {
  container.innerHTML = `
      <div class="gc-error">
        <p>${escapeHtml(message)}</p>
        <a
          href="https://github.com/${encodeURIComponent(username)}"
          target="_blank"
          rel="noopener noreferrer"
        >
          访问 GitHub 主页 →
        </a>
        ${showRetry
          ? `
          <button class="gc-retry-btn" data-username="${escapeHtml(username)}">
            重试
          </button>
        `
          : ''}
      </div>
    `

  // Setup retry button
  if (showRetry) {
    const retryBtn = container.querySelector('.gc-retry-btn')
    retryBtn?.addEventListener('click', () => {
      loadContributionGraph(container)
    })
  }
}

/**
 * Format date for display
 */
function formatDate(dateStr: string): string {
  const date = new Date(dateStr)
  const year = date.getFullYear()
  const month = date.getMonth() + 1
  const day = date.getDate()
  return `${year}年${month}月${day}日`
}

/**
 * Escape HTML to prevent XSS
 */
function escapeHtml(text: string): string {
  const div = document.createElement('div')
  div.textContent = text
  return div.innerHTML
}

/**
 * Initialize all contribution calendars
 */
function setupGitHubContribution(): void {
  const containers = document.querySelectorAll('.github-contribution-container')

  if (containers.length === 0) {
    return
  }

  Array.from(containers).forEach((container) => {
    loadContributionGraph(container as HTMLElement)
  })
}

// Support for Astro View Transitions
document.addEventListener('astro:page-load', setupGitHubContribution)
document.addEventListener('astro:after-swap', setupGitHubContribution)

// Initial load
setupGitHubContribution()

// Cleanup tooltip on page unload
window.addEventListener('beforeunload', hideTooltip)
</script>
