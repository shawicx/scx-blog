---
/**
 * Stats Page
 *
 * Displays development statistics including GitHub contributions.
 */

import GitHubContribution from '@/components/Widgets/GitHubContribution.astro'
import { themeConfig } from '@/config'
import Layout from '@/layouts/Layout.astro'

const siteTitle = themeConfig.site.title
const githubUsername = 'shawicx'
const githubToken = import.meta.env.GITHUB_TOKEN
---

<Layout postTitle={`统计 - ${siteTitle}`}>
  <!-- Decorative Line -->
  <div class="uno-decorative-line" />

  <!-- Page Header -->
  <div class="uno-page-header">
    <h1 class="uno-page-title">开发统计</h1>
    <p class="uno-page-subtitle">
      追踪我的开源贡献和开发活动
    </p>
  </div>

  <!-- GitHub Contribution Calendar -->
  <GitHubContribution
    username={githubUsername}
    title="GitHub 开源贡献"
    token={githubToken}
    showTotal={true}
  />

  <!-- Future expansion: More statistics -->
  <!--
  <div class="uno-section mt-8">
    <h2 class="uno-section-title">更多统计</h2>
    <p class="uno-section-text">敬请期待更多开发统计功能...</p>
  </div>
  -->
</Layout>

<style>
  .uno-page-header {
    --at-apply: 'mb-8';
  }

  .uno-page-title {
    --at-apply: 'text-3xl font-bold c-primary mb-2';
  }

  .uno-page-subtitle {
    --at-apply: 'text-base c-secondary/70';
  }

  .uno-section {
    --at-apply: 'uno-round-border bg-secondary/5 p-6';
  }

  .uno-section-title {
    --at-apply: 'text-xl font-semibold c-primary mb-3';
  }

  .uno-section-text {
    --at-apply: 'text-sm c-secondary/60';
  }
</style>
